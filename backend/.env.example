# ============================================================
# .env.example — Copy this to .env and fill in your values
# ============================================================

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=placement_db

# --- Flask Secret Key (CHANGE THIS to a long random string in production) ---
SECRET_KEY=change_me_to_a_long_random_secret_at_least_32_chars

# --- CORS (comma-separated origins; leave blank to use localhost:5173 default) ---
# Production example: CORS_ORIGINS=https://portal.example.edu,https://admin.example.edu
CORS_ORIGINS=

# --- Session Storage ---
# Use 'filesystem' for local dev.
# Use 'redis' for production (requires REDIS_URL below).
SESSION_TYPE=filesystem

# If SESSION_TYPE=redis, set the Redis connection URL:
# REDIS_URL=redis://localhost:6379/0

# Keep sessions alive across browser restarts (true/false)
SESSION_PERMANENT=false

# --- Cookie Security (set to true when deployed behind HTTPS) ---
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# --- CSRF Protection ---
CSRF_ENABLED=true
CSRF_HEADER=X-CSRF-Token
CSRF_SESSION_KEY=csrf_token
